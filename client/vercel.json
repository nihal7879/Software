{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://YOUR-BACKEND-URL/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
